      {
        "id": "a5b6c7d8-9e0f-4a1b-82d3-4e5f6a7b8c9d",
        "name": "Rank Spore Cloud",
        "slug": "rank-spore-cloud",
        "description": "<p>Rot spores erupt from cracks in the lair walls. Each creature within 20 ft. of the troll must succeed on a <strong>DC 12 Constitution saving throw</strong> or take <strong>2d6 poison damage</strong> and be <span class=\"wiki-link wiki-link--found\" data-wiki-id=\"b2e4d3c5-6f7a-4b8d-9e0f-1a2b3c4d5e6f\" data-wiki-type=\"statuses\" tabindex=\"0\" role=\"link\">Poisoned</span> until the start of its next turn.</p>",
        "type": "lair",
        "target": {
          "type": "area",
