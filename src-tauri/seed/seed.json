    "abilities": [
      {
        "id": "f6a8b7c9-0d1e-4f2a-8b4c-5d6e7f8a9b0c",
        "name": "Regeneration",
        "slug": "regeneration",
        "description": "<p>The troll regains <strong>10 hit points</strong> at the start of its turn if it has at least 1 HP. If the troll takes acid or fire damage, this trait does not function at the start of its next turn.</p>",
        "type": "passive",
        "castingTime": null,
        "requiresConcentration": false,
        "effects": [
          {
            "type": "custom",
            "description": "Regain 10 HP at the start of each turn. Suppressed for 1 turn after taking acid or fire damage.",
            "data": {
              "healPerTurn": 10,
              "suppressedBy": ["acid", "fire"]
            }
          }
        ],
        "createdAt": "2024-09-01T12:00:00.000Z",
        "updatedAt": "2024-09-01T12:00:00.000Z"
      },
      {
        "id": "a7b9c8d0-1e2f-4a3b-9c5d-6e7f8a9b0c1d",
        "name": "Crushing Slam",
        "slug": "crushing-slam",
        "description": "<p>The troll brings its club down in a devastating overhead arc. On a hit, the target takes bludgeoning damage and must succeed on a DC 13 Constitution saving throw or become <span class=\"wiki-link wiki-link--found\" data-wiki-id=\"a1f3c2d4-5e6b-4a7c-8d9e-0f1a2b3c4d5e\" data-wiki-type=\"statuses\" tabindex=\"0\" role=\"link\">Bleeding</span>.</p>",
        "type": "action",
        "target": {
          "type": "target",
          "range": 5,
          "count": 1
        },
        "castingTime": "1 action",
        "requiresConcentration": false,
        "effects": [
          {
            "type": "damage",
            "formula": "2d6 + 4",
            "damageType": "bludgeoning"
          },
          {
            "type": "applyStatus",
            "statusId": "a1f3c2d4-5e6b-4a7c-8d9e-0f1a2b3c4d5e",
            "duration": "until healed",
            "savingThrow": {
              "dc": 13,
              "attribute": "constitution"
            }
          }
        ],
        "createdAt": "2024-09-01T12:10:00.000Z",
        "updatedAt": "2024-09-01T12:10:00.000Z"
      },
      {
        "id": "b8c0d9e1-2f3a-4b4c-ad6e-7f8a9b0c1d2e",
        "name": "Thick Hide",
        "slug": "thick-hide",
        "description": "<p>When hit by an attack, the troll hunches and tenses its leathery hide. As a reaction it gains <strong>+2 AC</strong> against that attack, potentially turning the hit into a miss.</p>",
        "type": "reaction",
        "target": {
          "type": "selfTarget"
        },
        "castingTime": "1 reaction (when hit by an attack)",
        "requiresConcentration": false,
        "recharge": "short rest",
        "effects": [
          {
            "type": "custom",
            "description": "Gain +2 AC against the triggering attack retroactively.",
            "data": {
              "acBonus": 2,
              "trigger": "when hit by an attack",
              "retroactive": true
            }
          }
        ],
        "createdAt": "2024-09-01T12:20:00.000Z",
