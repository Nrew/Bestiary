    "entities": [
      {
        "id": "c9d1e0f2-3a4b-4c5d-be7f-8a9b0c1d2e3f",
        "name": "Forest Troll",
        "slug": "forest-troll",
        "taxonomy": {
          "genus": "Trollidae",
          "species": "Sylvanus regenerans",
          "subspecies": null
        },
        "size": "large",
        "threatLevel": "hard",
        "challengeRating": 5.0,
        "experiencePoints": 1800,
        "proficiencyBonus": 3,
        "legendaryActionsPerRound": 3,
        "savingThrows": {
          "strength": 7,
          "constitution": 8
        },
        "skills": {
          "perception": 2,
          "stealth": 4
        },
        "damageResistances": [
          { "damageType": "bludgeoning", "level": "resistant" },
          { "damageType": "fire", "level": "vulnerable" },
          { "damageType": "acid", "level": "vulnerable" }
        ],
        "statusImmunities": [],
        "senses": ["darkvision 60 ft."],
        "languages": ["Giant"],
        "habitats": ["forest", "swamp", "hills", "caves"],
        "description": "<h2>Appearance</h2><p>A hulking, moss-covered brute that lopes through old-growth forests on knuckled fists, its rubbery green hide dappled with lichen and old scars. Standing nearly 9 feet tall, the Forest Troll is a study in ugly efficiency — all reach and muscle and hunger.</p><h2>The <span class=\"wiki-link wiki-link--found\" data-wiki-id=\"f6a8b7c9-0d1e-4f2a-8b4c-5d6e7f8a9b0c\" data-wiki-type=\"abilities\" tabindex=\"0\" role=\"link\">Regeneration</span> Problem</h2><p>Forest Trolls are infamous for their ability to close wounds almost as fast as a blade can open them. Adventurers who have never faced one before are often horrified to watch a deep cut seal over in seconds. Only fire and acid leave wounds that truly stay open — a fact that separates experienced monster hunters from unlucky beginners.</p>",
        "statBlock": {
          "hp": 84,
          "hitDice": null,
          "armor": 15,
          "armorNote": null,
          "speed": 30.0,
          "burrowSpeed": null,
          "climbSpeed": 20,
          "flySpeed": null,
          "swimSpeed": null,
          "hoverSpeed": null,
          "initiativeBonus": null,
          "strength": 18,
          "dexterity": 13,
          "constitution": 20,
          "intelligence": 7,
          "wisdom": 9,
          "charisma": 7,
          "custom": {}
        },
        "statusIds": [],
        "abilityIds": [
          "f6a8b7c9-0d1e-4f2a-8b4c-5d6e7f8a9b0c",
          "a7b9c8d0-1e2f-4a3b-9c5d-6e7f8a9b0c1d",
