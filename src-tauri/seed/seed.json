      },
      {
        "id": "c1d2e3f4-5a6b-4c7d-8e9f-0a1b2c3d4e5f",
        "name": "Root Whip",
        "slug": "root-whip",
        "description": "<p>The troll wrenches a gnarled root from the earth and cracks it at one creature within 15 ft. The target must succeed on a <strong>DC 13 Dexterity saving throw</strong> or take <strong>1d8 bludgeoning damage</strong> and be knocked prone.</p>",
        "type": "legendary",
        "target": {
          "type": "target",
          "range": 15,
          "count": 1
        },
        "castingTime": "1 legendary action",
        "requiresConcentration": false,
        "effects": [
          {
            "type": "damage",
            "formula": "1d8",
            "damageType": "bludgeoning"
          }
        ],
        "createdAt": "2024-09-01T12:30:00.000Z",
