      },
      {
        "id": "d2e3f4a5-6b7c-4d8e-9f0a-1b2c3d4e5f6a",
        "name": "Predator's Scent",
        "slug": "predators-scent",
        "description": "<p>The troll fixes its sunken eyes on a creature within 60 ft. it can smell, reading its movement before it makes it. Until the end of the troll's next turn, it has <strong>advantage</strong> on the first attack roll it makes against that creature.</p>",
        "type": "legendary",
        "target": {
          "type": "target",
          "range": 60,
          "count": 1
        },
        "castingTime": "1 legendary action",
        "requiresConcentration": false,
        "effects": [
          {
            "type": "custom",
            "description": "Advantage on the next attack roll against the target.",
            "data": {
              "advantage": true,
              "duration": "until end of troll's next turn"
            }
          }
        ],
        "createdAt": "2024-09-01T12:35:00.000Z",
        "updatedAt": "2024-09-01T12:35:00.000Z"
      },
      {
        "id": "e3f4a5b6-7c8d-4e9f-a0b1-2c3d4e5f6a7b",
        "name": "Regenerative Surge",
        "slug": "regenerative-surge",
        "description": "<p>The troll abandons offense and lets its body knit. It immediately regains <strong>15 hit points</strong>. If its <span class=\"wiki-link wiki-link--found\" data-wiki-id=\"f6a8b7c9-0d1e-4f2a-8b4c-5d6e7f8a9b0c\" data-wiki-type=\"abilities\" tabindex=\"0\" role=\"link\">Regeneration</span> was suppressed, the suppression ends.</p>",
        "type": "legendary",
        "target": {
          "type": "selfTarget"
        },
        "castingTime": "2 legendary actions",
        "requiresConcentration": false,
        "effects": [
          {
            "type": "custom",
            "description": "Regain 15 hit points and remove Regeneration suppression.",
            "data": {
              "healing": 15,
              "clearsRegenSuppression": true
            }
          }
        ],
        "createdAt": "2024-09-01T12:40:00.000Z",
        "updatedAt": "2024-09-01T12:40:00.000Z"
      },
      {
        "id": "f4a5b6c7-8d9e-4f0a-b1c2-3d4e5f6a7b8c",
        "name": "Strangling Undergrowth",
        "slug": "strangling-undergrowth",
        "description": "<p>Roots and vines tear upward through the soil in a <strong>10-ft. radius</strong> around a point within 60 ft. Each creature in that area must succeed on a <strong>DC 13 Strength saving throw</strong> or be <strong>restrained</strong> until initiative count 20 on the next round.</p>",
        "type": "lair",
        "target": {
          "type": "area",
          "range": 60,
          "shape": "cylinder",
          "size": 10
        },
        "castingTime": null,
        "requiresConcentration": false,
        "effects": [
          {
            "type": "custom",
            "description": "Restrained on failed DC 13 Strength save until initiative count 20.",
            "data": {
              "condition": "restrained",
              "savingThrow": { "dc": 13, "attribute": "strength" },
