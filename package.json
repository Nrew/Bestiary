{
  "name": "bestiary",
  "private": false,
  "version": "1.0.0",
  "description": "An offline bestiary, item, and ability compendium for tabletop RPGs.",
  "author": "Nrew",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nrew/bestiary.git"
  },
  "homepage": "https://github.com/nrew/bestiary",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run types:generate && tsc --noEmit && vite build",
    "tauri": "tauri",
    "tauri:dev": "npm run types:generate && tauri dev",
    "tauri:build": "npm run build && tauri build",
    "test": "vitest",
    "lint": "npm run types:check && eslint .",
    "audit:npm": "npm audit --audit-level=moderate",
    "audit:rust": "cd src-tauri && cargo audit --ignore RUSTSEC-2023-0071",
    "verify": "npm run lint && npm run build && npm test -- --run && cd src-tauri && cargo fmt --check && cargo clippy --all-targets -- -D warnings && cargo test --locked",
    "verify:release": "npm run verify && npm run audit:npm && npm run audit:rust && npm run tauri:build",
    "format": "prettier --write .",
    "types:generate": "cd src-tauri && cargo test export_bindings --features ts-bindings",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.12",
    "@tauri-apps/api": "2.10.1",
    "@tiptap/react": "^3.6.6",
    "@tiptap/starter-kit": "^3.6.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "immer": "^10.1.3",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.65.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.1.14",
    "@tauri-apps/cli": "^2.8.4",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^6.0.4",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
