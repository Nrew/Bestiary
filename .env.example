# Environment Variables Template
# Copy this to .env.development or .env.production and modify as needed

# Rust logging level - suppress TAO event loop warnings
RUST_LOG=warn,bestiary=info,tao::platform_impl::platform::event_loop::runner=error

# Database URL (automatically set by application)
# DATABASE_URL=sqlite:./data/bestiary.sqlite

# Development settings
VITE_DEV_SERVER_PORT=1420
VITE_DEV_MODE=true
VITE_LOG_LEVEL=debug
VITE_BUILD_SOURCEMAP=true

# Production settings (use these values for .env.production)
# VITE_DEV_MODE=false
# VITE_LOG_LEVEL=error
# VITE_BUILD_SOURCEMAP=false

# Optional: Override app data directory
# BESTIARY_DATA_DIR=/path/to/custom/data/directory
